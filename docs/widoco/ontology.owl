<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/ns4kge/ontology#"
     xml:base="https://w3id.org/ns4kge/ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/ns4kge/ontology">
        <owl:versionIRI rdf:resource="https://w3id.org/ns4kge/ontology/1.0.0"/>
        <terms:bibliographicCitation xml:lang="en">Tebourski, I., Paris, P.-H., Preda, N., &amp; Sais, F. (2026). NS4KGE Ontology (v1.0.0). Zenodo. https://doi.org/10.5281/zenodo.20058306</terms:bibliographicCitation>
        <terms:creator>Fatiha Sais</terms:creator>
        <terms:creator>Ilyes Tebourski</terms:creator>
        <terms:creator>Nicoleta Preda</terms:creator>
        <terms:creator>Pierre-Henri Paris</terms:creator>
        <terms:description xml:lang="en">Ontology for representing scientific articles about negative sampling methods for knowledge graph embeddings.</terms:description>
        <terms:identifier>10.5281/zenodo.20058306</terms:identifier>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-06</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">NS4KGE Ontology</terms:title>
        <vann:preferredNamespacePrefix>ns4kge</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/ns4kge/ontology#</vann:preferredNamespaceUri>
        <rdfs:seeAlso rdf:resource="https://doi.org/10.5281/zenodo.20058306"/>
        <rdfs:seeAlso rdf:resource="https://github.com/IlyesTebourski/ns4kge-ontology"/>
        <owl:versionInfo>v1.0.0</owl:versionInfo>
    </owl:Ontology>
    


