@base <https://w3id.org/ns4kge/ontology#> .

<https://w3id.org/ns4kge/ontology> rdf:type owl:Ontology ;
                                    owl:versionIRI <https://w3id.org/ns4kge/ontology/1.0.0> ;
                                    <http://purl.org/dc/terms/bibliographicCitation> "Tebourski, I., Paris, P.-H., Preda, N., & Sais, F. (2026). NS4KGE Ontology (v1.0.0). Zenodo. https://doi.org/10.5281/zenodo.20058306"@en ;
                                    <http://purl.org/dc/terms/creator> "Fatiha Sais" ,
                                                                       "Ilyes Tebourski" ,
                                                                       "Nicoleta Preda" ,
                                                                       "Pierre-Henri Paris" ;
                                    <http://purl.org/dc/terms/description> "Ontology for representing scientific articles about negative sampling methods for knowledge graph embeddings."@en ;
                                    <http://purl.org/dc/terms/identifier> "10.5281/zenodo.20058306" ;
                                    <http://purl.org/dc/terms/issued> "2026-05-06"^^xsd:date ;
                                    <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                    <http://purl.org/dc/terms/title> "NS4KGE Ontology"@en ;
                                    <http://purl.org/vocab/vann/preferredNamespacePrefix> "ns4kge" ;
                                    <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/ns4kge/ontology#" ;
                                    rdfs:seeAlso <https://doi.org/10.5281/zenodo.20058306> ,
                                                 <https://github.com/IlyesTebourski/ns4kge-ontology> ;
                                    owl:versionInfo "v1.0.0" .

