@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix ns4kge: <https://w3id.org/ns4kge/ontology#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .

# -- Article
ns4kge:ArticleShape
    a sh:NodeShape ;
    sh:targetClass ns4kge:Article ;
    sh:property [ sh:path ns4kge:date ; sh:datatype xsd:gYear ] ;
    sh:property [ sh:path ns4kge:hasExperimentation ; sh:class ns4kge:Experimentation ] ;
    sh:property [ sh:path ns4kge:mentionsKGEModel ; sh:class ns4kge:KGEModel ] ;
    sh:property [ sh:path ns4kge:mentionsNSMethod ; sh:class ns4kge:NSMethod ] ;
    sh:property [ sh:path ns4kge:proposesKGEModel ; sh:class ns4kge:KGEModel ] ;
    sh:property [ sh:path ns4kge:proposesNSMethod ; sh:class ns4kge:NSMethod ] ;
    sh:property [ sh:path ns4kge:title ; sh:datatype xsd:string ] .

# -- Configuration
ns4kge:ConfigurationShape
    a sh:NodeShape ;
    sh:targetClass ns4kge:Configuration ;
    sh:property [ sh:path ns4kge:hasDataset ; sh:minCount 1 ; sh:maxCount 1 ; sh:class ns4kge:Dataset ] ;
    sh:property [ sh:path ns4kge:hasKGEModel ; sh:maxCount 1 ; sh:class ns4kge:KGEModel ] ;
    sh:property [ sh:path ns4kge:hasMetric ; sh:minCount 1 ; sh:maxCount 1 ; sh:class ns4kge:Metric ] ;
    sh:property [ sh:path ns4kge:hasNSMethod ; sh:maxCount 1 ; sh:class ns4kge:NSMethod ] ;
    sh:property [ sh:path ns4kge:hasTask ; sh:minCount 1 ; sh:maxCount 1 ; sh:class ns4kge:Task ] ;
    sh:property [ sh:path ns4kge:result ; sh:minCount 1 ; sh:maxCount 1 ; sh:datatype xsd:decimal ] .

# -- Experimentation
ns4kge:ExperimentationShape
    a sh:NodeShape ;
    sh:targetClass ns4kge:Experimentation ;
    sh:property [ sh:path ns4kge:hasConfiguration ; sh:minCount 1 ; sh:class ns4kge:Configuration ] ;
    sh:property [ sh:path ns4kge:hasTrainingProtocol ; sh:class ns4kge:TrainingProtocol ] .

# -- NSMethod
ns4kge:NSMethodShape
    a sh:NodeShape ;
    sh:targetClass ns4kge:NSMethod ;
    sh:property [ sh:path ns4kge:hasCategory ; sh:maxCount 1 ; sh:class ns4kge:Category ] ;
    sh:property [ sh:path ns4kge:hasEvaluationDimension ; sh:class ns4kge:EvaluationDimension ] ;
    sh:property [ sh:path ns4kge:hasSubcategory ; sh:maxCount 1 ; sh:class ns4kge:Subcategory ] .

# -- TrainingProtocol
ns4kge:TrainingProtocolShape
    a sh:NodeShape ;
    sh:targetClass ns4kge:TrainingProtocol ;
    sh:property [ sh:path ns4kge:hasHardware ; sh:class ns4kge:Hardware ] ;
    sh:property [ sh:path ns4kge:hasLossFunction ; sh:class ns4kge:LossFunction ] ;
    sh:property [ sh:path ns4kge:hasOptimizer ; sh:class ns4kge:Optimizer ] ;
    sh:property [ sh:path ns4kge:learningRate ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path ns4kge:nsRatio ; sh:maxCount 1 ; sh:datatype xsd:decimal ] .
